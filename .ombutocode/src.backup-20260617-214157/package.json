{
  "name": "ombuto-code",
  "version": "0.2.4",
  "description": "A GEN AI Assisted coding workflow manager built with Electron and Vue.js",
  "main": "./main.js",
  "scripts": {
    "postinstall": "node scripts/patch-electron-plist.js",
    "start": "electron .",
    "dev": "vite",
    "build": "vite build",
    "test": "node --test test/*.test.js",
    "test:kimi": "node --test test/*.test.js",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "headless": "node headless.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@electron/remote": "^2.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "dropbox": "^10.34.0",
    "electron-store": "^8.1.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.3",
    "node-pty": "^1.1.0",
    "pinia": "^3.0.3",
    "sharp": "^0.34.5",
    "simple-git": "^3.33.0",
    "sql.js": "^1.14.0",
    "tabulator-tables": "^6.3.1",
    "uuid": "^11.1.0",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4",
    "vuex": "^4.1.0",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.3.4",
    "concurrently": "^8.2.0",
    "electron": "^25.3.2",
    "electron-builder": "^24.3.0",
    "vite": "^4.4.4",
    "wait-on": "^7.0.1"
  },
  "build": {
    "protocols": [
      {
        "name": "OmbutoCode",
        "schemes": [
          "ombutocode"
        ],
        "role": "Viewer"
      }
    ],
    "appId": "com.ombutocode.app",
    "productName": "Ombuto Code",
    "asar": true,
    "npmRebuild": true,
    "artifactName": "OmbutoCode-Portable-${version}.exe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "main.js",
      "preload.js",
      "index.html",
      "src/assets/icon.ico",
      "src/assets/icon.png"
    ],
    "win": {
      "target": "portable",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
